# NetSuite Token-Based Authentication (TBA) Credentials
# Set these in Vercel Dashboard → Settings → Environment Variables
# NEVER commit actual values to git

NS_ACCOUNT_ID=9405258
NS_CONSUMER_KEY=your_consumer_key_here
NS_CONSUMER_SECRET=your_consumer_secret_here
NS_TOKEN_ID=your_token_id_here
NS_TOKEN_SECRET=your_token_secret_here

# Vercel KV (Upstash) — pick session storage
# Auto-set by the Vercel KV / Upstash integration; leave unset locally if you use `vercel env pull`
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Pick session TTL in seconds (default 172800 = 48h)
SESSION_TTL_SECONDS=172800

# Salesfloor receive-bin mapping per destination location (OPTIONAL).
# { destinationLocationId: binNumber } — used by /api/transfer-orders/:id/fulfill.
# If unset, the endpoint uses hardcoded GLWW defaults (location 3 → F-01-0001).
# Only set this to add a new destination location or override the default.
# NS_SALESFLOOR_BINS_JSON={"3":"F-01-0001"}

# Full URL of the deployed SuiteScript RESTlet that creates Item Receipts
# for Transfer Order fulfillments. See netsuite/README.md for one-time
# deployment instructions. Without this, Complete Pick leaves a stuck TO
# for an admin to receive manually.
# NS_RESTLET_RECEIVE_TO_URL=https://<acct>.restlets.api.netsuite.com/app/site/hosting/restlet.nl?script=<id>&deploy=<id>
